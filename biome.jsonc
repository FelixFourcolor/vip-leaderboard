{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"linter": {
		"includes": ["**/*.ts", "**/*.tsx", "!!**/*.gen.ts"],
		"rules": {
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"useIterableCallbackReturn": "off"
			},
			"correctness": {
				"useParseIntRadix": "off"
			},
			"a11y": "off"
		}
	}
}
