{
	"name": "vip-leaderboard",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"tscheck": "tsc --noEmit -p tsconfig.proj.json ; tsc --noEmit -p tsconfig.app.json",
		"db-reload": "rm public/db.sqlite; drizzle-kit push && tsx --tsconfig tsconfig.proj.json loader/main.ts",
		"db-update": "tsx --tsconfig tsconfig.proj.json loader/main.ts update"
	},
	"dependencies": {
		"@floating-ui/react": "^0.27.19",
		"@nivo/core": "^0.99.0",
		"@nivo/line": "^0.99.0",
		"@nivo/theming": "^0.99.0",
		"@tanstack/react-router": "^1.170.16",
		"@tanstack/router-plugin": "^1.168.18",
		"classnames": "^2.5.1",
		"d3-shape": "^3.2.0",
		"drizzle-orm": "^0.45.2",
		"es-toolkit": "^1.49.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-range": "^1.10.0",
		"sql.js": "^1.14.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/d3-shape": "^3.1.8",
		"@types/node": "^26.0.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/sql.js": "^1.4.11",
		"@vitejs/plugin-react": "^6.0.3",
		"better-sqlite3": "^12.11.1",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.22.4",
		"typescript": "~6.0.3",
		"vite": "^8.1.0"
	}
